{
  "name": "helihyrox",
  "private": true,
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "react-native-screens": "~4.16.0",
    "react-native-safe-area-context": "~5.6.0",
    "@react-navigation/native": "~7.1.14",
    "@react-navigation/native-stack": "~7.3.16",
    "@react-navigation/bottom-tabs": "~7.4.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:mobile": "cd apps/mobile && npx expo start",
    "dev:admin": "npm --workspace @helihyrox/admin run dev",
    "typecheck:mobile": "npm --workspace @helihyrox/mobile run typecheck",
    "typecheck:admin": "npm --workspace @helihyrox/admin run typecheck"
  }
}
